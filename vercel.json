{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "installCommand": "npm install",
  "crons": [
    { "path": "/api/cron/morning-queue", "schedule": "0 2 * * *" },
    { "path": "/api/cron/daily-summary", "schedule": "0 13 * * *" },
    { "path": "/api/cron/slow-day-alert", "schedule": "0 7 * * *" },
    { "path": "/api/cron/weekly-summary", "schedule": "0 14 * * 0" }
  ]
}
